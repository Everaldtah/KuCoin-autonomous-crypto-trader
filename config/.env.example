# ─── KuCoin Trading Bot Credentials ─────────────────────────────────────
# Get your keys from: https://www.kucoin.com/account/api
KUCOIN_API_KEY=your_api_key_here
KUCOIN_API_SECRET=your_api_secret_here
KUCOIN_PASSPHRASE=your_passphrase_here

# ─── Trading Parameters ─────────────────────────────────────────────────
# Initial balance for P&L tracking (set to your starting amount)
INITIAL_BALANCE=100.00

# Risk management (Kelly Criterion + ATR-based stops)
# Max risk per trade as % of total balance (professional standard: 1-2%)
MAX_RISK_PER_TRADE_PCT=2.0
# Max daily loss as % of starting balance
MAX_DAILY_LOSS_PCT=5.0
# Max portfolio drawdown from peak (%)
MAX_DRAWDOWN_PCT=15.0

# Legacy fixed stops (set to 0 to use ATR-based dynamic stops)
TAKE_PROFIT_PCT=0
STOP_LOSS_PCT=0

# Trading pair (supports any KuCoin spot pair)
TRADING_PAIR=ETH-USDT

# ─── Technical Indicators ────────────────────────────────────────────────
# RSI
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# MACD
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# Bollinger Bands
BB_PERIOD=20
BB_STD_DEV=2

# ATR (used for dynamic stops)
ATR_PERIOD=14

# Stochastic RSI
STOCH_RSI_PERIOD=14

# ADX (trend strength)
ADX_PERIOD=14

# ─── Multi-Timeframe Analysis ───────────────────────────────────────────
# Timeframes: 1hour, 4hour, 1day (comma-separated)
# Each gets full indicator suite, weighted by timeframe
# Higher timeframes have more weight in confluence scoring

# ─── Regime Detection ──────────────────────────────────────────────────
# Strategy auto-adjusts based on detected market regime:
#   strong_trend → full size, wide TP, trailing stops
#   weak_trend   → 75% size, moderate TP/SL
#   ranging      → 50% size, mean-reversion, no trailing
#   volatile     → 70% size, wider stops
#   quiet        → NO TRADING (await volatility)

# ─── Telegram Notifications (optional) ───────────────────────────────────
# Get bot token from @BotFather, chat ID from @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Advanced Settings ──────────────────────────────────────────────────
# Correlation risk (rapid loss cluster detection)
# CORRELATION_LOSS_WINDOW=300
# CORRELATION_LOSS_THRESHOLD=3

# Guard settings
# MAX_HOLD_HOURS=8
# MAX_CONSECUTIVE_FAILS=5
# MAX_TRADES_PER_HOUR=10

# Paths (defaults work for standard setup)
# STATE_FILE=data/trader_state.json
# LOG_FILE=logs/bot.log
# PID_FILE=data/bot.pid
# GUARD_STATE_FILE=data/guard_state.json
# DASHBOARD_STATE=data/bot_state.json
